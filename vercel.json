{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/PG-icon.png", "dest": "/PG-icon.png" },
    
    { "src": "/how-it-works", "dest": "/api/how-it-works.php" },
    { "src": "/faq", "dest": "/api/faq.php" },
    { "src": "/about", "dest": "/api/about.php" },
    { "src": "/contact", "dest": "/api/contact.php" },
    { "src": "/custom-development", "dest": "/api/custom-development.php" },
    { "src": "/emergency-support", "dest": "/api/emergency-support.php" },
    { "src": "/graphic-design", "dest": "/api/graphic-design.php" },
    { "src": "/accessibility", "dest": "/api/accessibility.php" },
    { "src": "/it-admin", "dest": "/api/it-admin.php" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },

    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}

