{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/script.js", "destination": "/script.js" },
    { "source": "/PG-icon.png", "destination": "/PG-icon.png" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/((?!api/).*)", "destination": "/api/$1.php" }
  ]
}
