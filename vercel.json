{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/services", "destination": "/api/services.php" },
    { "source": "/how-it-works", "destination": "/api/how-it-works.php" },
    { "source": "/faq", "destination": "/api/faq.php" }
  ]
}
