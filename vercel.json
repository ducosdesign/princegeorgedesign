{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/how-it-works", "dest": "/api/how-it-works.php" },
    { "src": "/faq", "dest": "/api/faq.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "projectSettings": {
    "nodeVersion": "20.x"
  }
}
